{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "pnpm",
  "reporters": [
    "html",
    "clear-text",
    "progress"
  ],
  "testRunner": "vitest",
  "plugins": [
    "@stryker-mutator/vitest-runner"
  ],
  "coverageAnalysis": "off",
  "ignorePatterns": [
    "**/*.css",
    "**/*.md",
    "**/*.json"
  ],
  "mutate": [
    "src/core/**/*.ts",
    "src/lib/**/*.ts",
    "!src/**/*.test.ts",
    "!src/**/*.spec.ts"
  ]
}
